<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>体験記事｜渡韓美容クリニックのカルテ</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Zen+Old+Mincho:wght@400;500;700;900&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.47.0/tabler-icons.min.css">
<style>
:root{
  --ink:#2A2329;          /* charcoal text */
  --ink-soft:#6B5E66;
  --ink-faint:#A89BA3;
  --paper:#FBF7F4;        /* warm paper */
  --paper-2:#F4ECE8;
  --rouge:#C2456A;        /* primary rouge */
  --rouge-deep:#9A2F4F;
  --rouge-soft:#F7E4EA;
  --gold:#B08A4F;         /* seal / accent gold */
  --line:rgba(42,35,41,0.10);
  --line-soft:rgba(42,35,41,0.06);
  --shadow:0 6px 26px rgba(120,70,90,0.10);
  --r:18px;
  --r-sm:11px;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'Zen Kaku Gothic New',sans-serif;
  color:var(--ink);
  background:var(--paper);
  line-height:1.7;
  -webkit-font-smoothing:antialiased;
}
.wrap{max-width:1000px;margin:0 auto;padding:0 20px}

/* ====== ambient paper background ====== */
.bg-field{position:fixed;inset:0;z-index:-1;background:var(--paper);overflow:hidden}
.bg-field::before{content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 60% 40% at 12% 0%, #FBE8EE 0%, transparent 55%),
    radial-gradient(ellipse 50% 36% at 100% 22%, #F3EBF2 0%, transparent 55%),
    radial-gradient(ellipse 70% 45% at 50% 108%, #FAEAE2 0%, transparent 60%);
  opacity:.85}
.bg-field::after{content:'';position:absolute;inset:0;opacity:.4;
  background-image:url("data:image/svg+xml,%3Csvg width='42' height='42' viewBox='0 0 42 42' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23C2456A' fill-opacity='0.05'%3E%3Ccircle cx='21' cy='21' r='1.2'/%3E%3C/g%3E%3C/svg%3E")}

/* ====== top utility bar ====== */
.topbar{display:flex;align-items:center;justify-content:space-between;padding:18px 0 14px;border-bottom:1px solid var(--line-soft)}
.brand{display:flex;align-items:baseline;gap:10px}
.brand .mark{font-family:'Zen Old Mincho',serif;font-weight:900;font-size:20px;letter-spacing:.04em;color:var(--ink)}
.brand .mark em{font-style:normal;color:var(--rouge)}
.brand .romaji{font-size:10px;letter-spacing:.32em;text-transform:uppercase;color:var(--ink-faint)}
.topbar .seal{font-size:10px;letter-spacing:.2em;color:var(--gold);border:1px solid var(--gold);border-radius:999px;padding:4px 11px;white-space:nowrap}
@media(max-width:560px){.topbar .seal{display:none}}

/* ====== hero ====== */
.hero{padding:54px 0 40px;position:relative}
.hero-eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--rouge);margin-bottom:22px}
.hero-eyebrow::before{content:'';width:26px;height:1px;background:var(--rouge);opacity:.6}
.hero h1{font-family:'Zen Old Mincho',serif;font-weight:700;font-size:clamp(30px,6vw,52px);line-height:1.28;letter-spacing:.01em;margin-bottom:22px}
.hero h1 .vert{color:var(--rouge)}
.hero h1 .sm{font-size:.5em;display:block;color:var(--ink-soft);letter-spacing:.06em;margin-top:14px;font-weight:500}
.hero-lead{font-size:15px;color:var(--ink-soft);max-width:560px;line-height:1.95}
.hero-stats{display:flex;gap:28px;margin-top:30px;flex-wrap:wrap}
.hstat{display:flex;flex-direction:column}
.hstat b{font-family:'Zen Old Mincho',serif;font-size:26px;color:var(--rouge-deep);line-height:1}
.hstat span{font-size:11px;color:var(--ink-faint);margin-top:6px;letter-spacing:.04em}
.hstat .div{width:1px;align-self:stretch;background:var(--line)}

/* ====== section frame ====== */
.section{padding:46px 0}
.section-tag{display:flex;align-items:center;gap:14px;margin-bottom:8px}
.section-tag .no{font-family:'Zen Old Mincho',serif;font-size:13px;color:var(--gold);letter-spacing:.1em;font-weight:700}
.section-tag .ln{flex:1;height:1px;background:var(--line)}
.section-tag .ja{font-size:11px;letter-spacing:.2em;color:var(--ink-faint)}
.section-title{font-family:'Zen Old Mincho',serif;font-size:clamp(22px,4vw,30px);font-weight:700;margin-bottom:10px;letter-spacing:.02em}
.section-sub{font-size:13.5px;color:var(--ink-soft);max-width:620px;margin-bottom:30px;line-height:1.85}

/* ====== KARTE FINDER (core tool) ====== */
.karte{background:rgba(255,255,255,0.78);border:1px solid var(--line);border-radius:var(--r);box-shadow:var(--shadow);backdrop-filter:blur(10px);overflow:hidden}
.karte-head{background:linear-gradient(110deg,var(--rouge) 0%,var(--rouge-deep) 100%);color:#fff;padding:20px 24px;display:flex;align-items:center;gap:14px;position:relative;overflow:hidden}
.karte-head::after{content:'問診';position:absolute;right:18px;top:50%;transform:translateY(-50%);font-family:'Zen Old Mincho',serif;font-size:54px;font-weight:900;color:rgba(255,255,255,0.10);letter-spacing:.1em}
.karte-head .ic{font-size:24px}
.karte-head h3{font-family:'Zen Old Mincho',serif;font-size:18px;font-weight:700;letter-spacing:.04em}
.karte-head p{font-size:11.5px;opacity:.82;margin-top:2px}
.karte-body{padding:8px 24px 24px}

.q-block{padding:22px 0;border-bottom:1px dashed var(--line)}
.q-block:last-of-type{border-bottom:none}
.q-label{display:flex;align-items:center;gap:9px;font-size:13px;font-weight:700;margin-bottom:14px;color:var(--ink)}
.q-label .q-no{width:22px;height:22px;border-radius:50%;background:var(--rouge-soft);color:var(--rouge-deep);font-size:11px;display:flex;align-items:center;justify-content:center;font-family:'Zen Old Mincho',serif;font-weight:700;flex-shrink:0}
.q-hint{font-size:11px;color:var(--ink-faint);font-weight:400;margin-left:4px}

.chips{display:flex;flex-wrap:wrap;gap:8px}
.chip{font-size:13px;padding:9px 16px;border-radius:999px;border:1px solid var(--line);background:#fff;color:var(--ink-soft);cursor:pointer;transition:all .18s;user-select:none}
.chip:hover{border-color:var(--rouge);color:var(--rouge)}
.chip.on{background:var(--rouge);border-color:var(--rouge);color:#fff;font-weight:700;box-shadow:0 3px 10px rgba(194,69,106,0.25)}
.chip .ti{font-size:14px;margin-right:5px;vertical-align:-1px}

/* type cards (axis 1) */
.type-cards{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.type-card{border:1.5px solid var(--line);border-radius:var(--r-sm);padding:16px 16px 14px;cursor:pointer;background:#fff;transition:all .18s;position:relative}
.type-card:hover{border-color:var(--rouge);transform:translateY(-2px)}
.type-card.on{border-color:var(--rouge);background:var(--rouge-soft);box-shadow:0 4px 14px rgba(194,69,106,0.16)}
.type-card .tc-ic{font-size:22px;color:var(--rouge);margin-bottom:8px}
.type-card h4{font-size:14px;font-weight:700;margin-bottom:5px;font-family:'Zen Old Mincho',serif}
.type-card p{font-size:11.5px;color:var(--ink-soft);line-height:1.65}
.type-card .check{position:absolute;top:12px;right:12px;width:20px;height:20px;border-radius:50%;border:1.5px solid var(--line);display:flex;align-items:center;justify-content:center;font-size:12px;color:transparent}
.type-card.on .check{background:var(--rouge);border-color:var(--rouge);color:#fff}

/* budget slider */
.budget-wrap{display:flex;align-items:center;gap:16px;flex-wrap:wrap}
.budget-wrap input[type=range]{flex:1;min-width:200px;accent-color:var(--rouge);height:4px}
.budget-val{font-family:'Zen Old Mincho',serif;font-size:20px;font-weight:700;color:var(--rouge-deep);min-width:128px;text-align:center;background:var(--paper-2);border-radius:var(--r-sm);padding:7px 12px}

/* karte footer / result count */
.karte-foot{background:var(--paper-2);padding:16px 24px;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;border-top:1px solid var(--line)}
.foot-count{font-size:13px;color:var(--ink-soft)}
.foot-count b{font-family:'Zen Old Mincho',serif;font-size:22px;color:var(--rouge-deep);margin:0 3px}
.btn-reset{font-size:12px;color:var(--ink-faint);background:none;border:none;cursor:pointer;text-decoration:underline;text-underline-offset:3px}
.btn-reset:hover{color:var(--rouge)}

/* ====== results: KARTE cards ====== */
.results{margin-top:30px;display:flex;flex-direction:column;gap:18px}
.result-lead{font-size:13px;color:var(--ink-soft);margin-bottom:4px}
.result-lead b{color:var(--rouge-deep)}
.kcard{background:rgba(255,255,255,0.92);border:1px solid var(--line);border-radius:var(--r);box-shadow:var(--shadow);overflow:hidden;position:relative;animation:rise .4s ease backwards}
@keyframes rise{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
.kcard-top{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;padding:18px 20px 14px;border-bottom:1px solid var(--line-soft)}
.kcard-rank{position:absolute;top:0;left:0;background:var(--ink);color:var(--paper);font-family:'Zen Old Mincho',serif;font-size:13px;font-weight:700;padding:5px 13px 6px;border-radius:0 0 var(--r-sm) 0;letter-spacing:.05em}
.kcard-rank.best{background:linear-gradient(120deg,var(--gold),#caa66a)}
.kcard h3{font-family:'Zen Old Mincho',serif;font-size:18px;font-weight:700;margin:14px 0 4px;letter-spacing:.02em;padding-left:2px}
.kcard .area{font-size:11.5px;color:var(--ink-faint);display:flex;align-items:center;gap:4px}
.type-badge{font-size:11px;font-weight:700;padding:5px 12px;border-radius:999px;white-space:nowrap;flex-shrink:0}
.type-badge.factory{background:#E7F1EC;color:#2E7D5B}
.type-badge.premium{background:#EFE7F3;color:#7A4A93}
.kcard-desc{padding:12px 20px 4px;font-size:13px;color:var(--ink-soft);line-height:1.8}

/* spec table — the "5 second" karte spec */
.spec-table{margin:12px 20px 18px;border:1px solid var(--line);border-radius:var(--r-sm);overflow:hidden}
.spec-row{display:grid;grid-template-columns:96px 1fr;border-bottom:1px solid var(--line-soft);font-size:12.5px}
.spec-row:last-child{border-bottom:none}
.spec-row dt{background:var(--paper-2);padding:9px 12px;color:var(--ink-soft);font-weight:700;display:flex;align-items:center;gap:5px}
.spec-row dd{padding:9px 13px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.spec-yes{color:#2E7D5B;font-weight:700;display:inline-flex;align-items:center;gap:3px}
.spec-no{color:var(--ink-faint);display:inline-flex;align-items:center;gap:3px}
.pricepill{font-family:'Zen Old Mincho',serif;font-weight:700;color:var(--rouge-deep)}
.t-pill{font-size:11px;padding:2px 9px;border-radius:999px;background:var(--rouge-soft);color:var(--rouge-deep)}

.kcard-foot{display:flex;gap:10px;flex-wrap:wrap;padding:0 20px 18px;align-items:center}
.btn-hp{display:inline-flex;align-items:center;gap:6px;font-size:12.5px;font-weight:700;text-decoration:none;padding:9px 18px;border-radius:999px;color:#fff;background:linear-gradient(120deg,var(--rouge),var(--rouge-deep));box-shadow:0 3px 12px rgba(194,69,106,0.28);transition:transform .15s}
.btn-hp:hover{transform:translateY(-1px)}
.btn-map{display:inline-flex;align-items:center;gap:5px;font-size:12.5px;text-decoration:none;color:var(--gold);font-weight:700}
.btn-map:hover{opacity:.7}

.empty{text-align:center;padding:40px 20px;color:var(--ink-soft);font-size:13.5px;border:1px dashed var(--line);border-radius:var(--r);background:rgba(255,255,255,0.5)}
.empty .ti{font-size:30px;color:var(--ink-faint);display:block;margin-bottom:10px}

/* ====== article nav cards ====== */
.art-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px}
.art-card{display:block;text-decoration:none;color:inherit;background:rgba(255,255,255,0.85);border:1px solid var(--line);border-radius:var(--r);padding:24px 22px 22px;transition:all .2s;position:relative;overflow:hidden}
.art-card::before{content:attr(data-kanji);position:absolute;right:-6px;bottom:-18px;font-family:'Zen Old Mincho',serif;font-size:80px;font-weight:900;color:var(--rouge);opacity:.05;line-height:1;pointer-events:none}
.art-card:hover{transform:translateY(-4px);box-shadow:var(--shadow);border-color:var(--rouge)}
.art-card .ac-ic{width:46px;height:46px;border-radius:13px;background:var(--rouge-soft);color:var(--rouge);display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:16px}
.art-card .ac-kicker{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:7px}
.art-card h4{font-family:'Zen Old Mincho',serif;font-size:16px;font-weight:700;margin-bottom:8px;letter-spacing:.02em}
.art-card p{font-size:12.5px;color:var(--ink-soft);line-height:1.75;margin-bottom:14px}
.art-card .ac-go{font-size:12px;font-weight:700;color:var(--rouge);display:inline-flex;align-items:center;gap:4px}

/* ====== footer ====== */
.foot{margin-top:50px;background:var(--ink);color:rgba(251,247,244,0.6);padding:44px 0 30px}
.foot .brand .mark{color:#fff}.foot .brand .mark em{color:var(--rouge-soft)}
.foot .brand .romaji{color:rgba(255,255,255,0.3)}
.foot-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:28px 0 24px}
.foot-block{background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.07);border-radius:12px;padding:15px 17px}
.foot-block h5{font-size:12px;font-weight:700;color:rgba(255,255,255,0.78);margin-bottom:7px;display:flex;align-items:center;gap:6px}
.foot-block p{font-size:11px;color:rgba(255,255,255,0.42);line-height:1.8}
.foot-copy{font-size:10.5px;color:rgba(255,255,255,0.28);text-align:center;border-top:1px solid rgba(255,255,255,0.08);padding-top:18px;line-height:1.8}

@media(max-width:640px){
  .type-cards{grid-template-columns:1fr}
  .foot-grid{grid-template-columns:1fr}
  .kcard-top{flex-direction:column}
  .spec-row{grid-template-columns:84px 1fr}
  .hero-stats{gap:18px}
  .hstat .div{display:none}
}
/* ====== global nav ====== */
.topbar{position:relative}
.nav{display:flex;align-items:center;gap:4px}
.nav a{font-size:13px;color:var(--ink-soft);text-decoration:none;padding:8px 13px;border-radius:999px;transition:all .16s;white-space:nowrap;letter-spacing:.02em}
.nav a:hover{color:var(--rouge);background:var(--rouge-soft)}
.nav a.active{color:var(--rouge-deep);font-weight:700}
.nav a.cta{background:var(--rouge);color:#fff;font-weight:700;margin-left:6px}
.nav a.cta:hover{background:var(--rouge-deep);color:#fff}
.nav-toggle{display:none;background:none;border:1px solid var(--line);border-radius:10px;width:40px;height:38px;cursor:pointer;font-size:20px;color:var(--ink);align-items:center;justify-content:center}
@media(max-width:860px){
  .topbar .seal{display:none}
  .nav-toggle{display:flex}
  .nav{position:absolute;top:calc(100% + 8px);right:0;left:0;flex-direction:column;align-items:stretch;gap:2px;
    background:rgba(255,255,255,0.97);backdrop-filter:blur(12px);border:1px solid var(--line);border-radius:14px;
    padding:8px;box-shadow:var(--shadow);z-index:50;display:none}
  .nav.open{display:flex;animation:rise .2s ease}
  .nav a{padding:12px 14px;border-radius:10px;font-size:14px}
  .nav a.cta{margin-left:0;margin-top:4px;text-align:center}
}
</style>
<style>
/* ===== subpage extras ===== */
.page-hero{padding:46px 0 30px}
.page-hero .crumb{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-faint);margin-bottom:16px}
.page-hero .crumb a{color:var(--ink-faint);text-decoration:none}
.page-hero .crumb a:hover{color:var(--rouge)}
.page-hero h1{font-family:'Zen Old Mincho',serif;font-weight:700;font-size:clamp(26px,5vw,40px);line-height:1.3;margin-bottom:14px;letter-spacing:.02em}
.page-hero h1 em{font-style:normal;color:var(--rouge)}
.page-hero p{font-size:14.5px;color:var(--ink-soft);max-width:620px;line-height:1.9}
.post-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px;padding:10px 0 20px}
.post{display:flex;flex-direction:column;background:rgba(255,255,255,0.88);border:1px solid var(--line);border-radius:var(--r);overflow:hidden;text-decoration:none;color:inherit;transition:all .2s}
.post:hover{transform:translateY(-4px);box-shadow:var(--shadow);border-color:var(--rouge)}
.post-thumb{height:150px;display:flex;align-items:center;justify-content:center;font-size:40px;color:#fff;position:relative;overflow:hidden}
.post-thumb::after{content:attr(data-kanji);position:absolute;right:-8px;bottom:-22px;font-family:'Zen Old Mincho',serif;font-size:100px;font-weight:900;color:rgba(255,255,255,0.16);line-height:1}
.tg-a{background:linear-gradient(125deg,#C2456A,#9A2F4F)}
.tg-b{background:linear-gradient(125deg,#B08A4F,#8a6c3a)}
.tg-c{background:linear-gradient(125deg,#7A4A93,#5a3470)}
.tg-d{background:linear-gradient(125deg,#2E7D5B,#1f5d42)}
.post-body{padding:18px 18px 20px;flex:1;display:flex;flex-direction:column}
.post-cat{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-bottom:9px;display:flex;align-items:center;gap:7px}
.post-cat .date{color:var(--ink-faint);letter-spacing:.04em}
.post h3{font-family:'Zen Old Mincho',serif;font-size:16.5px;font-weight:700;line-height:1.5;margin-bottom:9px}
.post p{font-size:12.5px;color:var(--ink-soft);line-height:1.75;flex:1}
.post .go{font-size:12px;font-weight:700;color:var(--rouge);margin-top:14px;display:inline-flex;align-items:center;gap:4px}
.tags-row{display:flex;gap:8px;flex-wrap:wrap;margin:6px 0 24px}
.tagf{font-size:12.5px;padding:7px 15px;border-radius:999px;border:1px solid var(--line);background:#fff;color:var(--ink-soft);cursor:default}
.tagf.on{background:var(--rouge);border-color:var(--rouge);color:#fff;font-weight:700}
.soon{background:rgba(255,255,255,0.6);border:1px dashed var(--line);border-radius:var(--r);padding:30px 24px;text-align:center;color:var(--ink-soft);font-size:13.5px;margin-top:6px}
.soon .ti{font-size:30px;color:var(--ink-faint);display:block;margin-bottom:10px}
.backhome{display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:700;color:var(--rouge);text-decoration:none;margin:8px 0 0}
</style>
</head>
